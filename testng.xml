<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="N11.com E2E Test Suite" verbose="2">

    <test name="All Tests">
        <classes>
            <class name="com.n11.runners.CucumberRunner"/>
        </classes>
    </test>

    <test name="Smoke Tests">
        <classes>
            <class name="com.n11.runners.SmokeTestRunner"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <classes>
            <class name="com.n11.runners.RegressionTestRunner"/>
        </classes>
    </test>

</suite>